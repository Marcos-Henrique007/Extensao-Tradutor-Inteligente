{
  "manifest_version": 3,
  "name": "Tradutor Inteligente",
  "version": "2.0",
  "description": "Traduz textos selecionados na página",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ]
    }
  ]
}